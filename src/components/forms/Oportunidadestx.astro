 <section class="form-section" data-form="Oportunidadestx">
    <div class="app-container">
      <form class="container" data-endpoint="/api/Oportunidadestx/">
        <h2>Oportunidades en Texas</h2>

        <input required name="nombre" placeholder="Nombre" />
        <input required name="email" type="email" placeholder="Email" />
        <input required name="sector" placeholder="Sector de interés" />
        <textarea required name="mensaje" rows="4" placeholder="¿Qué oportunidades buscas?"></textarea>

        <button type="submit">Enviar</button>
        <p class="feedback"></p>
      </form>
    </div>
  </section>